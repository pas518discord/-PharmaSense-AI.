# ==============================================================================
# PharmaSense AI — Environment Configuration Template
# Note: Copy to .env and fill in your values. Never commit .env to git.
# ==============================================================================

# ------------------------------------------------------------------------------
# Google Gemini AI Orchestration
# ------------------------------------------------------------------------------
# Your API key for Google AI Studio to run cloud-connected decision loops.
# Obtain a free or paid key from: https://aistudio.google.com/
# If left blank, the system automatically runs using local offline fallback trees.
GEMINI_API_KEY=your_gemini_api_key_here

# ------------------------------------------------------------------------------
# Splunk HTTP Event Collector (HEC) — Telemetry Streaming
# ------------------------------------------------------------------------------
# The destination endpoint URL for the Splunk HEC receiver.
# For local development, the default port is usually 8088.
SPLUNK_HEC_URL=https://localhost:8088

# The authorization token generated during Splunk HEC configuration.
# Set up in Splunk via: Settings > Data Inputs > HTTP Event Collector
SPLUNK_HEC_TOKEN=your_splunk_hec_token_here

# ------------------------------------------------------------------------------
# Splunk REST API & MCP Server Context Queries
# ------------------------------------------------------------------------------
# The management port URL used to run search queries for context gathering.
# For local standalone Splunk instances, the default REST port is 8089.
SPLUNK_REST_URL=https://localhost:8089

# Administrative username for Splunk authentication.
SPLUNK_USER=admin

# Password for the specified Splunk administrative account.
SPLUNK_PASSWORD=your_splunk_password_here

# ------------------------------------------------------------------------------
# Human-in-the-Loop (HITL) Notification Workflows
# ------------------------------------------------------------------------------
# Slack webhook used to dispatch interactive alert blocks for CRITICAL risks.
# Optional. If not configured, human-in-the-loop alerts log straight to stdout.
# Do not place real webhook URLs in committed files.
SLACK_WEBHOOK_URL=your_slack_webhook_url_here

# ------------------------------------------------------------------------------
# Local Node & Engine Configurations
# ------------------------------------------------------------------------------
# Identifies the geographical or organizational facility location running this engine node.
# Standard defaults are site_a, site_b, or site_c.
PHARMASENSE_SITE=site_a

# Frequency in seconds at which the continuous simulation background worker 
# advances the state-machine timeline and outputs telemetry metrics.
SIMULATION_INTERVAL_SECONDS=15

# System console and file telemetry logging filtering threshold.
# Acceptable levels: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
